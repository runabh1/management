# Dependencies
node_modules/
.npm/

# Environment secrets — NEVER commit this
backend/.env
.env
.env.local
.env.*.local

# Database (ephemeral — seeded fresh on deploy)
backend/smartcampus.db
backend/smartcampus.db-shm
backend/smartcampus.db-wal

# Uploads folder (ephemeral on Render free tier)
backend/uploads/*
!backend/uploads/.gitkeep

# Frontend build output (Render builds this automatically)
frontend/dist/

# Logs
logs/
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
